generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model tauthor {
  nAuthorID Int     @id @default(autoincrement())
  cName     String
  cSurname  String?
}

model tbook {
  nBookID              Int      @id @default(autoincrement())
  cTitle               String
  nAuthorID            Int
  nPublishingYear      Decimal?
  nPublishingCompanyID Int

  @@index([nAuthorID], map: "idx_tbook_IDX_BOOK_AUTHOR_ID")
  @@index([nPublishingCompanyID], map: "idx_tbook_IDX_BOOK_PUBLISHING_COMPANY_ID")
}

model tpublishingcompany {
  nPublishingCompanyID Int    @id @default(autoincrement())
  cName                String
}
